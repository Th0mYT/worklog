<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.worklog.poller</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Replace with the absolute path to your Python / uv binary -->
        <string>/usr/local/bin/python3</string>
        <string>-m</string>
        <string>logger.activity_poller</string>
    </array>

    <!-- Absolute path to the worklog project root -->
    <key>WorkingDirectory</key>
    <string>/Users/YOURNAME/path/to/worklog</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!-- stdout / stderr go to ~/.worklog/logs/ -->
    <key>StandardOutPath</key>
    <string>/Users/YOURNAME/.worklog/poller.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/YOURNAME/.worklog/poller.error.log</string>

    <!-- Restart 10 s after a crash -->
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
